rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    // create: allow any authenticated user (onAuthStateChanged timing race means
    //   request.auth.uid == userId can momentarily fail right after account creation)
    // read/update/delete: only the owner
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Projects collection - authenticated government officers can read/write
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Schemes collection - anyone can read, authenticated gov officers can write
    match /schemes/{schemeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Contractors collection - anyone can read, authenticated users can create
    match /contractors/{contractorId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Government Officials collection - authenticated users can read/write
    match /government_officials/{officialId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Complaints collection - authenticated users can read/write
    match /complaints/{complaintId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    
    // Contractor ratings collection
    match /contractorRatings/{ratingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
    
    // Allow public read for demo purposes (adjust based on your security needs)
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
