# ═══════════════════════════════════════════════════════════════════════
# INDIA INNOVATES - Environment Configuration
# Copy this file to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════
# AI/ML API KEYS
# ═══════════════════════════════════════════════════════════════════════

# OpenAI API Key (required for chatbot service)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini API Key (optional - for enhanced verification)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Maps API Key (required for maps)
# Get your key from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ═══════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# PostgreSQL Database URL
DATABASE_URL=postgresql://postgres:password@postgres:5432/india_innovates

# PostgreSQL Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=india_innovates

# ═══════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

REDIS_URL=redis://:redispassword@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# ═══════════════════════════════════════════════════════════════════════
# KAFKA CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

KAFKA_BROKER=kafka:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ═══════════════════════════════════════════════════════════════════════
# ELASTICSEARCH CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ═══════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════

# Environment (development, staging, production)
NODE_ENV=production
ENVIRONMENT=production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend API URL
BACKEND_API_URL=http://localhost:5000

# AI Service URL
AI_SERVICE_URL=http://localhost:8000

# Chatbot Service URL
CHATBOT_SERVICE_URL=http://localhost:8001

# ═══════════════════════════════════════════════════════════════════════
# SECURITY SETTINGS
# ═══════════════════════════════════════════════════════════════════════

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session Secret
SESSION_SECRET=your-session-secret-key-change-this

# ═══════════════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION (optional - for hosting)
# ═══════════════════════════════════════════════════════════════════════

FIREBASE_PROJECT_ID=avyanpragati
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=avyanpragati.firebaseapp.com

# ═══════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (optional - for notifications)
# ═══════════════════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ═══════════════════════════════════════════════════════════════════════
# MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════════════

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Enable detailed logging
DEBUG=false

# ═══════════════════════════════════════════════════════════════════════
# PERFORMANCE TUNING
# ═══════════════════════════════════════════════════════════════════════

# Redis cache TTL (seconds)
CACHE_TTL=3600

# Max upload file size (MB)
MAX_FILE_SIZE=10

# Rate limiting (requests per minute)
RATE_LIMIT=100

# ═══════════════════════════════════════════════════════════════════════
# DEVELOPMENT SETTINGS (comment out in production)
# ═══════════════════════════════════════════════════════════════════════

# Enable hot reload
WATCH_MODE=true

# Disable SSL verification (dev only)
NODE_TLS_REJECT_UNAUTHORIZED=0
